{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "rootDir": "..",
  "testMatch": ["<rootDir>/test/e2e/**/*.test.ts"],
  "moduleFileExtensions": ["ts", "js", "json"],
  "collectCoverage": true,
  "coverageDirectory": "<rootDir>/coverage/e2e",
  "verbose": true,
  "setupFilesAfterEnv": ["<rootDir>/test/setup/setupTests.ts"]
}




